PORT=4000
NODE_ENV=development
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key
FRONTEND_ORIGIN=http://localhost:5173

# Auth (Google SSO via Supabase Auth). Leave SUPABASE_ANON_KEY empty to run
# without sign-in (legacy open mode, local development only).
SUPABASE_ANON_KEY=your-anon-public-key
AUTH_ALLOWED_DOMAIN=everstage.com
AUTH_DEFAULT_ROLE=reviewer

# Optional: required when creating new PRDF/Jira tickets from the dashboard
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=PRDF
JIRA_ISSUE_TYPE=Task
JIRA_CREATED_LABEL=cs-db-created
JIRA_PRDF_CREATE_URL=https://your-company.atlassian.net/secure/CreateIssueDetails!init.jspa?pid=12345&issuetype=10001
